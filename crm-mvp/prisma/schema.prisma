// 既提供「当天真实点击 C」，也提供「过去 7 天日均基线 B」（B/4=每小时补点击上限）。
// click_date 按 UTC+8（联盟 click_time 时区）切日，与平台后台口径一致。
// 仅存计数，不落点击明细（低配机省存储）；同步游标存 system_configs(key=click_sync_cursor_{connId})。
// -----------------------------------------------------------
model affiliate_click_daily {
  id                     BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                BigInt   @db.UnsignedBigInt
  platform               String   @db.VarChar(8)
  merchant_id            String   @db.VarChar(64) // 平台商家标识（与 affiliate_transactions.merchant_id 同口径）
  platform_connection_id BigInt?  @db.UnsignedBigInt
  click_date             DateTime @db.Date // 自然日（UTC+8）
  clicks                 Int      @default(0) @db.UnsignedInt
  is_deleted             Int      @default(0) @db.TinyInt
  created_at             DateTime @default(now()) @db.DateTime(0)
  updated_at             DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([user_id, platform, merchant_id, click_date], map: "uk_user_plat_merchant_date")
  @@index([user_id, click_date], map: "idx_click_user_date")
  @@index([user_id, merchant_id, click_date], map: "idx_click_user_merchant_date")
}

