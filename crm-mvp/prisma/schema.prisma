/// 月度结算追踪表
/// 每个用户每个月一行，记录该月佣金的状态分布与是否已结算。
/// 当 pending_count = 0 时自动标记 is_settled=1，daily-sync 不再请求该月平台 API。
model monthly_settlement_status {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id         BigInt    @db.UnsignedBigInt
  month           String    @db.VarChar(7) // YYYY-MM
  total_count     Int       @default(0) @db.UnsignedInt
  total_amount    Decimal   @default(0.00) @db.Decimal(14, 2)
  pending_count   Int       @default(0) @db.UnsignedInt
  pending_amount  Decimal   @default(0.00) @db.Decimal(14, 2)
  approved_count  Int       @default(0) @db.UnsignedInt
  approved_amount Decimal   @default(0.00) @db.Decimal(14, 2)
  paid_count      Int       @default(0) @db.UnsignedInt
  paid_amount     Decimal   @default(0.00) @db.Decimal(14, 2)
  rejected_count  Int       @default(0) @db.UnsignedInt
  rejected_amount Decimal   @default(0.00) @db.Decimal(14, 2)
  is_settled      Int       @default(0) @db.TinyInt // 0=未结算 1=已结算
  settled_at      DateTime? @db.DateTime(0)
  last_synced_at  DateTime? @db.DateTime(0)
  is_deleted      Int       @default(0) @db.TinyInt
  created_at      DateTime  @default(now()) @db.DateTime(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@unique([user_id, month], map: "uk_user_month")
  @@index([is_settled, user_id], map: "idx_settled_user")
}

