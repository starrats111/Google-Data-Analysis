// -----------------------------------------------------------
// 33. ATC 广告情报 — 团队共享缓存快照
// -----------------------------------------------------------
model merchant_atc_snapshots {
  id                    BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  domain                String   @db.VarChar(255)
  region                String   @default("US") @db.VarChar(8)
  raw_advertiser_count  Int      @default(0) @db.UnsignedInt
  real_advertiser_count Int      @default(0) @db.UnsignedInt
  top_advertisers_json  Json?
  sample_ads_json       Json?
  fetched_at            DateTime @db.DateTime(0)
  created_at            DateTime @default(now()) @db.DateTime(0)
  updated_at            DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([domain, region], map: "uk_domain_region")
}

// -----------------------------------------------------------
// 34c. C-093 广告主域名分布快照（团队级共享，TTL 7 天）
//   维度：(advertiser_id, region) 全局唯一
//   用途：判定一个 advertiser 是「同行联盟客（多域名）」还是「品牌自投（单域名）」
//   每次反查消耗 1 次 SerpApi，缓存 7 天供整个团队复用
// -----------------------------------------------------------
model atc_advertiser_domain_snapshot {
  id                      BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  advertiser_id           String   @db.VarChar(64)
  region                  String   @default("US") @db.VarChar(8)
  advertiser_name         String?  @db.VarChar(255)
  unique_domain_count     Int      @default(0) @db.UnsignedInt
  /**
   * C-094.1：满足「单广告持续 ≥30 天」的 domain 数（判定 peer 的核心字段）
   */
  qualifying_domain_count Int      @default(0) @db.UnsignedInt
  ad_count                Int      @default(0) @db.UnsignedInt
  /**
   * C-094.1 后存 DomainCreativeStat[]；C-093 旧数据是 string[]；空数组+ad_count>0 视为旧 bug 重算
   */
  domains_json            Json?
  /**
   * C-094.2：本快照写入时是否仍有 OCR 任务未完成（true 时 service 重读应返回 pending）
   */
  ocr_pending             Int      @default(0) @db.TinyInt
  /**
   * C-094.3：本次 SerpApi 采样的图片 URL + first_shown/last_shown，OCR 跑完后供 cache 命中时重算分类，避免重复调 SerpApi
   */
  sampled_ads_json        Json?
  fetched_at              DateTime @db.DateTime(0)
  created_at              DateTime @default(now()) @db.DateTime(0)
  updated_at              DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([advertiser_id, region], map: "uk_advertiser_region")
  @@index([fetched_at], map: "idx_fetched_at")
}

// -----------------------------------------------------------
// 34b. C-088 ATC 广告 — OCR 投放域名提取缓存
// 维度：image_url 全局唯一，跨用户/跨商家共享
// -----------------------------------------------------------
model ad_image_ocr_cache {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  image_url         String    @unique(map: "uk_image_url") @db.VarChar(768)
  status            String    @default("pending") @db.VarChar(20)
  extracted_domain  String?   @db.VarChar(255)
  raw_output        String?   @db.VarChar(512)
  tries             Int       @default(0) @db.UnsignedInt
  last_error        String?   @db.VarChar(512)
  model_used        String?   @db.VarChar(64)
  prompt_tokens     Int?      @db.UnsignedInt
  completion_tokens Int?      @db.UnsignedInt
  lock_at           DateTime? @db.DateTime(0)
  created_at        DateTime  @default(now()) @db.DateTime(0)
  updated_at        DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([status, lock_at], map: "idx_status_lock")
}

// -----------------------------------------------------------
// 34. ATC 广告情报 — 用户 SerpApi Key 多账号池
// -----------------------------------------------------------
model user_serpapi_keys {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt   @db.UnsignedBigInt
  key_name   String   @db.VarChar(64) // 用户自定义备注名，如 "Key1"、"工作账号"
  api_key    String   @db.VarChar(128)
  is_active  Int      @default(1) @db.TinyInt
  is_deleted Int      @default(0) @db.TinyInt
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, is_active], map: "idx_user_active")
}

// -----------------------------------------------------------
// 34b. 方案-09：员工自配 SemRush(3UE) 账号 —— 每员工各用各账号配额，根治共享账号批量设备超限
// 字段对标全局 system_configs.semrush_*（username/password/user_id/api_key/node/database）
// 密码明文存储（与现状 system_configs 一致，Q09-d）。
// -----------------------------------------------------------
model user_semrush_keys {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id     BigInt   @db.UnsignedBigInt
  key_name    String   @db.VarChar(64) // 用户自定义备注名
  username    String   @db.VarChar(128) // 3UE 登录用户名
  password    String   @db.VarChar(255) // 3UE 登录密码（明文，Q09-d）
  user_id_3ue String   @db.VarChar(64) // 3UE userId
  api_key     String   @db.VarChar(128) // 3UE api_key
  node        String   @default("3") @db.VarChar(8) // 节点
  database    String   @default("us") @db.VarChar(8) // 默认库（按投放国动态覆盖）
  is_active   Int      @default(1) @db.TinyInt
  is_deleted  Int      @default(0) @db.TinyInt
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, is_active], map: "idx_user_active")
}

// -----------------------------------------------------------
// 35. ATC 广告情报 — 商家监控告警规则（Phase 2 预建）
// -----------------------------------------------------------
model merchant_monitor_rules {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id          BigInt   @db.UnsignedBigInt
  user_merchant_id BigInt   @db.UnsignedBigInt
  rule_type        String   @db.VarChar(32)
  threshold_pct    Int      @default(20) @db.UnsignedTinyInt
  is_active        Int      @default(1) @db.TinyInt
  is_deleted       Int      @default(0) @db.TinyInt
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id], map: "idx_user")
}

// -----------------------------------------------------------
// 36. C-089 ATC 广告情报 — 用户关注的广告主（watchlist）
// min_days 默认 30（v2：07 明确要求 30 天+ 才推）
// -----------------------------------------------------------
model user_atc_watchlist {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id         BigInt   @db.UnsignedBigInt
  advertiser_id   String   @db.VarChar(64)
  advertiser_name String?  @db.VarChar(255)
  region          String   @default("US") @db.VarChar(8)
  min_days        Int      @default(30)
  /**
   * C-094.6：是否分享给同事（出现在「推荐广告主」列表）
   */
  is_shared       Int      @default(0) @db.TinyInt
  is_deleted      Int      @default(0) @db.TinyInt
  created_at      DateTime @default(now()) @db.DateTime(0)
  updated_at      DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([user_id, advertiser_id, region], map: "uk_user_adv_region")
  @@index([user_id, is_deleted], map: "idx_user_deleted")
  @@index([is_shared, is_deleted], map: "idx_shared")
}

// -----------------------------------------------------------
// 37. C-089 v2 ATC 广告情报 — 推送日志（每 creative 每天只推一次，跨天可重推）
// uk_user_creative_date 实现"日报"语义：同 user × 同 creative × 同 alerted_date 唯一
// -----------------------------------------------------------
model user_atc_alert_log {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id       BigInt   @db.UnsignedBigInt
  watchlist_id  BigInt   @db.UnsignedBigInt
  advertiser_id String   @db.VarChar(64)
  creative_id   String   @db.VarChar(64)
  days          Int
  alerted_date  DateTime @db.Date // CST 推送当天的日期
  alerted_at    DateTime @default(now()) @db.DateTime(0)

  @@unique([user_id, creative_id, alerted_date], map: "uk_user_creative_date")
  @@index([watchlist_id], map: "idx_watchlist")
}

// -----------------------------------------------------------
// 35. D-038c-v2 I6 — SemRush 关键词结果 24h 缓存兜底
// 用途：3UE 抽风时回退使用缓存关键词（黄色 toast 提示），保障广告创建流程不中断
// -----------------------------------------------------------
model semrush_keyword_cache {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  domain     String   @db.VarChar(255) // normalizeDomain 后的纯域名
  database   String   @db.VarChar(8) // SemRush db 码（us/uk/fr 等）
  payload    String   @db.LongText // 完整 /api/user/ad-creation/semrush 响应 data JSON
  raw_kw_cnt Int      @default(0) @db.UnsignedInt // 用于监控缓存质量
  cached_at  DateTime @default(now()) @db.DateTime(0)
  expires_at DateTime @db.DateTime(0) // 写入时设为 cached_at + 24h
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([domain, database], map: "uk_domain_db")
  @@index([expires_at], map: "idx_expires_at")
}

// -----------------------------------------------------------
// 36. D-038c-v2 I1 — SemRush 健康检查日志（cron 每整点写入，保留 7 天）
// -----------------------------------------------------------
model semrush_health_logs {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  checked_at DateTime @default(now()) @db.DateTime(0)
  overall    String   @db.VarChar(16) // success / failure
  error_type String?  @db.VarChar(32) // none / apikey / login / rpc_empty / unknown
  details    String?  @db.LongText // 完整步骤日志 JSON
  alerted    Int      @default(0) @db.TinyInt // 是否已触发 admin 告警（去重防刷）

  @@index([checked_at], map: "idx_checked_at")
  @@index([error_type, checked_at], map: "idx_errtype_time")
}

// -----------------------------------------------------------
// R-01. 月度收支报表 — 收款方式清单（组长维护，组员绑定）
// 替代 platform_connections.payee 文本字段：组长在 team-settings 维护
// 「收款人姓名 + 卡号」清单，组员为每个联盟账号选一条绑定。
// -----------------------------------------------------------
model payment_methods {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  team_id    BigInt   @db.UnsignedBigInt
  payee_name String   @db.VarChar(64)
  card_no    String   @db.VarChar(64)
  is_deleted Int      @default(0) @db.TinyInt
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([team_id, is_deleted], map: "idx_pm_team")
}

// -----------------------------------------------------------
// R-02. 月度收支报表 — 手填覆盖值（一表三用，scope_key 区分）
//   mcc:{mccId}                       组员广告费覆盖（原币，人×MCC×月）
//   recv:{platform}:{account}:{H1|H2} 组员实收手工纠正（USD，半月桶）
//   actual_cny                        组长手填实际佣金（CNY，人×月）
// 报表读取时覆盖值优先；无覆盖回退库内计算值。
// -----------------------------------------------------------
model report_overrides {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt   @db.UnsignedBigInt
  month      String   @db.VarChar(7) // YYYY-MM
  scope_key  String   @db.VarChar(64)
  value      Decimal  @default(0.00) @db.Decimal(14, 2)
  remark     String?  @db.VarChar(200)
  updated_by BigInt?  @db.UnsignedBigInt
  is_deleted Int      @default(0) @db.TinyInt
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([user_id, month, scope_key], map: "uk_ro_user_month_scope")
  @@index([month], map: "idx_ro_month")
}

// -----------------------------------------------------------
// R-03. 月度收支报表 — 收款方式绑定月度快照（历史月固化）
// 历史月报表首次生成时把「当时绑定」冗余固化（存文本防清单改名/删除），
// 之后该月只读快照，组员换绑不影响历史月显示。
// -----------------------------------------------------------
model payment_binding_snapshots {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt   @db.UnsignedBigInt
  month        String   @db.VarChar(7) // YYYY-MM
  platform     String   @db.VarChar(8)
  account_name String   @db.VarChar(32) // trim 后的账号名（与报表动态列 key 一致）
  payee_name   String   @default("") @db.VarChar(64)
  card_no      String   @default("") @db.VarChar(64)
  created_at   DateTime @default(now()) @db.DateTime(0)

  @@unique([user_id, month, platform, account_name], map: "uk_pbs_user_month_acct")
}

// -----------------------------------------------------------
// R-07. 银行流水 — 平台总打款入账登记（组长核对每个收款方式的收款）
// 平台打款是打给收款卡的「总打款」；组长录入 到账时间+实际总金额，
// 系统按该卡该平台该半月的员工实收(CNY)生效值自动预填明细，
// 手续费 = 员工明细合计(expected_amount) − 实际入账(amount) 自动计算。
// 明细可改（breakdown JSON），改后 expected/fee 同步重算。
// 期初余额存 report_overrides scope=`bank_open:{paymentMethodId}`（组长 user_id），
// 导出正规银行流水单时用于逐笔滚动余额。
// -----------------------------------------------------------
model bank_flow_entries {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  team_id           BigInt   @db.UnsignedBigInt
  month             String   @db.VarChar(7) // YYYY-MM（归属报表月）
  payment_method_id BigInt   @db.UnsignedBigInt // payment_methods.id（收款方式=收款卡）
  txn_at            DateTime @db.DateTime(0) // 到账日期时间（组长输入 xx号xx时间）
  platform          String   @db.VarChar(8) // 打款平台（对账维度）
  source_date       DateTime? @db.Date // 预填来源批次日（平台实际打款日），同批次不再重复预填；手工明细为 NULL
  counterparty      String   @default("") @db.VarChar(128) // 对方户名（默认平台打款主体，可改）
  summary           String   @default("佣金结算") @db.VarChar(128) // 交易摘要
  amount            Decimal  @default(0.00) @db.Decimal(14, 2) // 实际总打款入账金额
  currency          String   @default("CNY") @db.VarChar(8)
  expected_amount   Decimal  @default(0.00) @db.Decimal(14, 2) // 员工明细合计（自动）
  fee               Decimal  @default(0.00) @db.Decimal(14, 2) // 手续费 = expected − amount（自动）
  breakdown         String?  @db.Text // 员工明细 JSON [{userId,username,displayName,platform,account,amount}]
  remark            String?  @db.VarChar(255)
  created_by        BigInt?  @db.UnsignedBigInt
  is_deleted        Int      @default(0) @db.TinyInt
  created_at        DateTime @default(now()) @db.DateTime(0)
  updated_at        DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([team_id, month, is_deleted], map: "idx_bfe_team_month")
  @@index([payment_method_id], map: "idx_bfe_method")
}

// -----------------------------------------------------------
// 37. D-041 / Policy Hub — Google Ads 政策违规事实表
// 数据源：Google Ads API mutate 返回的 PolicyViolationDetails（深度解析见 src/lib/policy-hub/error-parser.ts）
// 用途：①拒登可统计/分析（admin 后台看板）；②top 违规规则反向优化 prompt；③商家政策画像数据源
// 软删除：本表为审计事实表，不软删；resolved_at 为「已修复时间」标记
// -----------------------------------------------------------
model policy_violations {
  id                          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  campaign_id                 BigInt?   @db.UnsignedBigInt // campaigns.id（可空：未提交前 final gate 也会写入）
  user_merchant_id            BigInt?   @db.UnsignedBigInt
  user_id                     BigInt?   @db.UnsignedBigInt
  mcc_id                      BigInt?   @db.UnsignedBigInt
  google_customer_id          String?   @db.VarChar(32) // Google CID（不带 dash）
  campaign_name               String?   @db.VarChar(255) // 便于看板显示
  merchant_domain             String?   @db.VarChar(255)
  country                     String?   @db.VarChar(8)
  // 4 大类映射（policy-categories.ts）
  policy_category             String    @db.VarChar(32) // prohibited / prohibited_practices / restricted / editorial_technical / unknown
  policy_subcategory          String    @db.VarChar(64) // 子项 slug，对应 D-042 政策知识库 markdown 路径
  policy_label_zh             String    @db.VarChar(64) // 中文显示名
  policy_official_url         String    @db.VarChar(512) // Google 官方政策原文 URL
  // Google Ads API 原始字段
  error_code                  String    @db.VarChar(128) // 如 "policyViolationError:POLICY_ERROR"
  policy_name                 String    @db.VarChar(128) // policyViolationDetails.key.policyName，如 "trademark_in_ad_text"
  external_policy_name        String?   @db.VarChar(128) // 如 "Trademarks"
  external_policy_description String?   @db.Text
  // 违规位置与文本
  evidence_field              String    @db.VarChar(64) // 可读化字段（"标题3" / "Sitelink desc1" / "Callout 文本"）
  evidence_index              Int       @default(-1) @db.Int // mutate_operations 顶层 index（-1 表示无）
  violating_text              String?   @db.Text // policyViolationDetails.key.violatingText，如 "BLACK+DECKER"
  trigger_value               String?   @db.Text // 原始 trigger 值
  field_path                  String?   @db.VarChar(512) // 原始 fieldPath（mutate_operations[5] > ad > headlines[3]）
  // 严重度 + 修复建议
  severity                    String    @default("warning") @db.VarChar(16) // critical / warning / minor
  suggested_fix               String?   @db.Text
  is_exemptible               Int       @default(0) @db.TinyInt // 是否可申诉
  // 元数据
  google_raw_error_json       String?   @db.LongText // 原始错误体（前 3000 字符）
  message                     String?   @db.Text // Google Ads message 原文
  submitted_at                DateTime  @default(now()) @db.DateTime(0) // 广告提交时间
  resolved_at                 DateTime? @db.DateTime(0) // 已修复时间（员工重新提交成功后由 admin 看板手动标记 / 自动检测）
  created_at                  DateTime  @default(now()) @db.DateTime(0)
  updated_at                  DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([campaign_id], map: "idx_campaign")
  @@index([user_id, submitted_at], map: "idx_user_time")
  @@index([user_merchant_id, submitted_at], map: "idx_merchant_time")
  @@index([policy_category, policy_subcategory], map: "idx_category")
  @@index([policy_name], map: "idx_policy_name")
  @@index([severity, resolved_at], map: "idx_severity_resolved")
  @@index([submitted_at], map: "idx_submitted_at")
}

// -----------------------------------------------------------
// 38. 团队 Developer Token 池（组长配置，Google Ads API 429 轮询用）
// 每条 = Developer Token + 对应 Service Account JSON 的配对凭证；
// 员工 MCC 里的 token/JSON 降级为兜底，不再要求员工配置。
// -----------------------------------------------------------
model team_developer_tokens {
  id                   BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  team_id              BigInt   @db.UnsignedBigInt
  token                String   @db.VarChar(64)
  service_account_json String?  @db.Text // 与该 token 配对的 Service Account JSON（一起轮换）
  daily_quota          Int      @default(15000) @db.UnsignedInt // 该 token 的每日操作配额（Basic 级默认 15000）
  label                String?  @db.VarChar(64) // 备注，如"MCC 468-xxx 的 token"
  is_active            Int      @default(1) @db.TinyInt
  created_by           BigInt?  @db.UnsignedBigInt
  is_deleted           Int      @default(0) @db.TinyInt
  created_at           DateTime @default(now()) @db.DateTime(0)
  updated_at           DateTime @default(now()) @updatedAt @db.DateTime(0)

  // ── 系统自动标记（真实流量 + 主动探测学习，无需人工维护）──
  health_status     String?   @default("unknown") @db.VarChar(16) // ok | invalid | limited | unknown
  health_note       String?   @db.VarChar(255) // 最近一次异常/探测结论（人话）
  last_ok_at        DateTime? @db.DateTime(0) // 最近一次成功请求/探测通过
  last_error_at     DateTime? @db.DateTime(0) // 最近一次失效/限额时间
  detected_quota    Int?      @db.UnsignedInt // 触顶反推出的真实每日额度（未触顶为 null）
  quota_detected_at DateTime? @db.DateTime(0)
  mcc_access        String?   @db.Text // JSON {"<mcc客户号>":"ok"|"denied"}——该凭证对各 MCC 的实测可用性
  cooldown_until    DateTime? @db.DateTime(0) // 冷却截止（限流/失效/额度耗尽）；重启后回灌内存冷却表

  @@index([team_id, is_deleted], map: "idx_tdt_team")
}

// -----------------------------------------------------------
// 38.1 Token 每日用量（token 池诊断：今日已用/使用方）
// requests 按 API 请求数累计（≈ Google 的 operations 口径下限）；
// mcc_ids 存当日经此 token 发请求的 MCC 客户号集合（JSON 数组），
// 展示「使用人数」时由 MCC → 持有用户反查。
// -----------------------------------------------------------
model token_usage_daily {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  token      String   @db.VarChar(64)
  date       DateTime @db.Date
  requests   Int      @default(0) @db.UnsignedInt
  mcc_ids    String?  @db.Text
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([token, date], map: "uk_tud_token_date")
}

// -----------------------------------------------------------
// Google Ads API 配额审计账本（批次5，参照 kyads google_ads_api_usage）
// token_usage_daily 只有 token+日 粒度，答不了「配额被谁烧掉的」；
// 本表按 日+token+MCC+CID+操作类型 聚合计数（内存缓冲批量 upsert，低配机友好），
// rate_limited 记录该维度触发 429 的次数，用于定位打爆配额的调用方。
// -----------------------------------------------------------
model google_ads_api_usage {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  date         DateTime @db.Date
  token        String   @db.VarChar(64)
  mcc_id       String   @db.VarChar(32) // 不带横杠
  customer_id  String   @default("") @db.VarChar(32) // 不带横杠；MCC 级操作为空串
  kind         String   @default("query") @db.VarChar(16) // query / mutate
  requests     Int      @default(0) @db.UnsignedInt
  rate_limited Int      @default(0) @db.UnsignedInt
  created_at   DateTime @default(now()) @db.DateTime(0)
  updated_at   DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([date, token, mcc_id, customer_id, kind], map: "uk_gaau_key")
  @@index([date, mcc_id], map: "idx_gaau_date_mcc")
}

// -----------------------------------------------------------
// 广告决策日志（批次6，参照 kyads decision_journal）
// analyze-campaigns cron 每日按 7 天表现给每个在投系列生成一条建议；
// track-outcomes cron 在建议后 3/7 天回填实际走势并评判建议对错，
// 形成「建议 → 结果 → 准确率」闭环，评估决策规则质量。
// -----------------------------------------------------------
model ad_decision_journal {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  decision_id   String    @unique(map: "uk_adj_decision_id") @db.VarChar(64) // campaignId_YYYY-MM-DD，天然幂等
  user_id       BigInt    @db.UnsignedBigInt
  campaign_id   BigInt    @db.UnsignedBigInt // campaigns.id
  campaign_name String    @db.VarChar(255)
  snapshot_json Json // 建议时点的 7 天表现快照（CampaignSnapshot）
  action_type   String    @db.VarChar(20) // pause / decrease_budget / increase_budget / keep / observe
  magnitude     String?   @db.VarChar(32) // 如 "-30%" / "+20%"
  reasoning     String?   @db.Text
  outcome_3d    Json? // 建议后 3 天实际走势（OutcomeData）
  outcome_7d    Json? // 建议后 7 天实际走势
  verdict       String?   @db.VarChar(20) // correct / partial / wrong / no_data（按 7d 评判）
  is_deleted    Int       @default(0) @db.TinyInt
  created_at    DateTime  @default(now()) @db.DateTime(0)
  updated_at    DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, created_at], map: "idx_adj_user_created")
  @@index([campaign_id, created_at], map: "idx_adj_campaign_created")
  @@index([verdict], map: "idx_adj_verdict")
}
