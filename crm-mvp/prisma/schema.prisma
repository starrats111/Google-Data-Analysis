// -----------------------------------------------------------
// 32a2. 换链接 — 刷点击「子项」（移植 kylink ClickTaskItem）
// 每条子项 = 一次按人类作息曲线排程的点击，cron 到期后执行
// -----------------------------------------------------------
model kyads_click_task_items {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  task_id      BigInt    @db.UnsignedBigInt // 关联 kyads_click_tasks.id
  scheduled_at DateTime  @db.DateTime(0) // 计划执行时间（按目标国作息曲线分布到当天）
  status       String    @default("pending") @db.VarChar(16) // pending / executing / success / failed
  exit_ip      String?   @db.VarChar(64)
  error        String?   @db.VarChar(500)
  executed_at  DateTime? @db.DateTime(0)
  duration_ms  Int?      @db.UnsignedInt
  is_deleted   Int       @default(0) @db.TinyInt
  created_at   DateTime  @default(now()) @db.DateTime(0)
  updated_at   DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([status, scheduled_at], map: "idx_status_scheduled")
  @@index([task_id, status], map: "idx_task_status")
}

// -----------------------------------------------------------
// 32b. 换链接 — 代理出口 IP 使用记录（24h 去重，移植 kylink ProxyExitIpUsage）
// -----------------------------------------------------------
model proxy_exit_ip_usage {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id     BigInt   @db.UnsignedBigInt
  campaign_id BigInt   @db.UnsignedBigInt
  exit_ip     String   @db.VarChar(64)
  used_at     DateTime @default(now()) @db.DateTime(0)
  expires_at  DateTime @db.DateTime(0) // 过期时间（默认 used_at + 24h）

  @@index([user_id, campaign_id, exit_ip], map: "idx_user_campaign_ip")
  @@index([expires_at], map: "idx_expires")
}

// -----------------------------------------------------------
// 32c. 换链接 — 告警中心（链接无效/商家库找不到/低库存/补货失败）
// -----------------------------------------------------------
model suffix_alerts {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt    @db.UnsignedBigInt
  campaign_id  BigInt?   @db.UnsignedBigInt // 关联 campaigns.id（可空，部分告警无 campaign）
  type         String    @db.VarChar(32) // invalid_link / merchant_not_found / low_stock / replenish_failed
  level        String    @default("warning") @db.VarChar(16) // info / warning / error
  message      String    @db.VarChar(500)
  context      Json? // 快照：campaignName / platform / mid / affiliateUrl / reason 等
  status       String    @default("open") @db.VarChar(16) // open / resolved
  occur_count  Int       @default(1) @db.UnsignedInt // 同类告警收敛计数
  last_seen_at DateTime  @default(now()) @db.DateTime(0)
  resolved_at  DateTime? @db.DateTime(0)
  is_deleted   Int       @default(0) @db.TinyInt
  created_at   DateTime  @default(now()) @db.DateTime(0)
  updated_at   DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, status, type], map: "idx_user_status_type")
  @@index([campaign_id, type, status], map: "idx_campaign_type_status")
