// CRM SaaS MVP — Prisma Schema
// 基于 CRM_MVP_数据库设计.sql 生成
// 规则：无外键约束、软删除、含 created_at / updated_at

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// -----------------------------------------------------------
// 0. 团队/小组表
// -----------------------------------------------------------
model teams {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  team_code  String   @unique(map: "uk_team_code") @db.VarChar(20)
  team_name  String   @db.VarChar(50)
  leader_id  BigInt?  @db.UnsignedBigInt
  // 组长控制的隐私开关：0=关闭（默认，本组成员看不到其他组的投放情况，「在投详情」只显示本组成员）
  //                    1=开启（本组成员可查看其他组的投放情况）
  cross_team_visible Int @default(0) @db.TinyInt
  is_deleted Int      @default(0) @db.TinyInt
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @default(now()) @updatedAt @db.DateTime(0)
}

// -----------------------------------------------------------
// 1. 用户表
// -----------------------------------------------------------
model users {
  id                        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  username                  String   @unique(map: "uk_username") @db.VarChar(64)
  password_hash             String   @db.VarChar(255)
  plain_password            String?  @db.VarChar(128)
  role                      String   @default("user") @db.VarChar(16)
  status                    String   @default("active") @db.VarChar(16)
  team_id                   BigInt?  @db.UnsignedBigInt
  display_name              String?  @db.VarChar(50)
  script_api_key            String?  @unique(map: "uk_script_api_key") @db.VarChar(64) // Google Ads Script 鉴权 Key，格式 ky_live_xxx
  kylink_api_key            String?  @db.VarChar(64) // kylink(换链接系统) 个人 API Key，格式 ky_live_xxx；用于把 CRM 商家库联盟链接自动喂给 kylink
  kylink_linked_at          DateTime? @db.DateTime(0) // 最近一次成功连接 kylink 的时间（测试连接通过即更新）
  kylink_username           String?  @db.VarChar(255) // 该 API Key 对应的 kylink 账号标识（邮箱/姓名），测试连接成功时记录，便于辨认绑定的是谁
  link_exchange_click_count Int      @default(10) @db.UnsignedInt // 换链接工作台：上次设置的每广告刷点击数，新同步广告默认沿用
  link_exchange_disabled    Int      @default(0) @db.TinyInt // 1=该用户只同步数据、不参与换链接（如 jy 交垟队）；从 Google 回填的新广告不自动开换链，UI 也禁止开启
  click_control_enabled     Int      @default(1) @db.TinyInt // 需求2：订单/点击比控制刷点击的用户级开关，默认开。1=开启「有订单→按 10-20:1 自动补刷联盟点击」，0=该用户关闭
  click_control_ratio_min_pct Int    @default(5) @db.TinyInt  // 需求2：转化率(订单/点击)控制区间下限(%)，默认5。员工可在换链接页配置
  click_control_ratio_max_pct Int    @default(10) @db.TinyInt // 需求2：转化率(订单/点击)控制区间上限(%)，默认10
  script_loop_interval_seconds Int?  @db.UnsignedSmallInt // 换链脚本轮询间隔(秒)，用户自助调节；NULL=用默认15。脚本启动经 /api/v1/suffix/script-config 读取，改后下轮自动生效无需重发脚本
  serpapi_key               String?  @db.VarChar(128) // 个人 SerpApi API Key（广告情报功能）
  atc_default_min_days      Int      @default(30) @db.UnsignedInt // 我的广告主-全局阈值，新增关注 / 统一设置时使用
  is_deleted                Int      @default(0) @db.TinyInt
  created_at                DateTime @default(now()) @db.DateTime(0)
  updated_at                DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([team_id], map: "idx_team_id")
}

// -----------------------------------------------------------
// 2. AI 供应商表
// -----------------------------------------------------------
model ai_providers {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  provider_name String   @db.VarChar(32)
  api_key       String   @db.Text
  api_base_url  String?  @db.VarChar(512)
  status        String   @default("active") @db.VarChar(16)
  is_deleted    Int      @default(0) @db.TinyInt
  created_at    DateTime @default(now()) @db.DateTime(0)
  updated_at    DateTime @default(now()) @updatedAt @db.DateTime(0)
}

// -----------------------------------------------------------
// 3. AI 场景模型分配表
// -----------------------------------------------------------
model ai_model_configs {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  scene       String   @db.VarChar(32)
  provider_id BigInt   @db.UnsignedBigInt
  model_name  String   @db.VarChar(64)
  max_tokens  Int?     @default(4096) @db.UnsignedInt
  temperature Decimal? @default(0.70) @db.Decimal(3, 2)
  is_active   Int      @default(1) @db.TinyInt
  priority    Int      @default(1) @db.UnsignedTinyInt
  is_deleted  Int      @default(0) @db.TinyInt
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([scene, is_active, priority], map: "idx_scene_active")
}

// -----------------------------------------------------------
// 4. 系统配置表
// -----------------------------------------------------------
model system_configs {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  config_key   String   @unique(map: "uk_config_key") @db.VarChar(128)
  config_value String?  @db.Text
  description  String?  @db.VarChar(255)
  is_deleted   Int      @default(0) @db.TinyInt
  created_at   DateTime @default(now()) @db.DateTime(0)
  updated_at   DateTime @default(now()) @updatedAt @db.DateTime(0)
}

// -----------------------------------------------------------
// 5. 联盟平台连接表
// -----------------------------------------------------------
model platform_connections {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id              BigInt    @db.UnsignedBigInt
  platform             String    @db.VarChar(8)
  account_name         String    @default("") @db.VarChar(32) // 账号名称，如 RW1, RW2
  // D-168：账号位次（07 规则）——同用户同平台第 1 个账号=1、第 2 个=2；删除释放位次，
  // 新账号补最小空缺（删 2 加第 4 个 → 新账号=2）。系列名平台段序号（LH2）按此映射到连接。
  account_index        Int?      @db.UnsignedInt
  api_key              String?   @db.Text
  channel_id           String?   @db.VarChar(64) // 历史遗留（AD 平台已下线），保留不再使用
  payee                String?   @db.VarChar(64) // D-077：该账号打款的收款人（如 张文俊 / 龚建成）。R-01 起弃用，改用 payment_method_id
  payment_method_id    BigInt?   @db.UnsignedBigInt // R-01：绑定的收款方式（payment_methods.id），组员在设置页选择
  publish_site_id      BigInt?   @db.UnsignedBigInt // 绑定的发布站点（管理员创建的全局站点）
  // D-026 status 取值：connected | error | unverified | disconnected
  // 默认 unverified（新建未测试），test-connection 成功 → connected，sync 失败 → error
  status               String    @default("connected") @db.VarChar(16)
  last_synced_at       DateTime? @db.DateTime(0)
  // D-026 新增 3 字段：API 健康监控
  last_sync_attempt_at DateTime? @db.DateTime(0) // 上次尝试同步时间（成功/失败都写）
  last_error           String?   @db.VarChar(500) // 上次错误消息（成功后清空）
  consecutive_failures Int       @default(0) @db.UnsignedInt // 连续失败次数（成功后清零，>=1 切红灯）
  is_deleted           Int       @default(0) @db.TinyInt
  created_at           DateTime  @default(now()) @db.DateTime(0)
  updated_at           DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, platform], map: "idx_user_platform")
  @@index([status, last_sync_attempt_at], map: "idx_status_attempt") // D-026: 健康巡检 cron 用
}

// -----------------------------------------------------------
// 6. 商家库表
// -----------------------------------------------------------
model user_merchants {
  id                        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                   BigInt    @db.UnsignedBigInt
  platform                  String    @db.VarChar(8)
  merchant_id               String    @db.VarChar(64)
  merchant_name             String    @db.VarChar(255)
  merchant_url              String?   @db.VarChar(512)
  logo_url                  String?   @db.VarChar(1024)
  category                  String?   @db.VarChar(128)
  // D-166：1=主营业务被人工修正过（编辑时同域名/同MID全系统同步），平台同步不再覆盖 category
  category_manual           Int       @default(0) @db.TinyInt
  commission_rate           String?   @db.VarChar(64)
  cookie_duration           Int?      @db.UnsignedInt
  supported_regions         Json?
  status                    String    @default("available") @db.VarChar(16)
  claimed_at                DateTime? @db.DateTime(0)
  target_country            String?   @db.VarChar(8)
  holiday_name              String?   @db.VarChar(128)
  tracking_link             String?   @db.VarChar(1024)
  campaign_link             String?   @db.Text // 联盟平台推广链接
  // C-020 URL 直投来源标记（R1.1 入档 §20.5.2）
  source                    String    @default("platform") @db.VarChar(16) // platform / url_direct
  listing_status            String    @default("active") @db.VarChar(16) // active / offline / url_only
  // 违规/推荐标记（从 Google Sheets 同步）
  violation_status          String    @default("normal") @db.VarChar(20) // normal / violated
  violation_time            DateTime? @db.DateTime(0)
  recommendation_status     String    @default("normal") @db.VarChar(20) // normal / recommended
  recommendation_time       DateTime? @db.DateTime(0)
  // 政策审核标记（商家同步时自动检测）
  policy_status             String    @default("pending") @db.VarChar(16) // pending / clean / restricted / prohibited
  policy_category_code      String?   @db.VarChar(32) // 匹配到的政策类别代码，如 alcohol / gambling
  platform_connection_id    BigInt?   @db.UnsignedBigInt // 关联到具体平台账号
  connection_campaign_links Json? // 各账号推广链接 {"conn_id": "campaign_link_url", ...}
  // 链接可达性检测
  link_status               String    @default("unchecked") @db.VarChar(16) // unchecked / valid / invalid
  link_checked_at           DateTime? @db.DateTime(0)
  link_check_reason         String?   @db.VarChar(255)
  // D-1xx 追踪链接 + 上级联盟自动巡航（创建广告时按投放国代理跟随联盟追踪链接的跳转链）
  parent_network            String?   @db.VarChar(64) // 识别到的上级联盟 label（小写，如 awin / impact / cj）
  parent_blacklisted        Int       @default(0) @db.TinyInt // 该平台下命中上级联盟黑名单 = 1
  tracking_status           String    @default("unchecked") @db.VarChar(20) // unchecked / ok / no_tracking / forbidden_network / resolve_failed
  resolved_final_url        String?   @db.VarChar(1024) // 巡航跟到的最终落地 URL
  resolve_chain             Json? // 整条跳转链（每一跳 URL）
  parent_checked_at         DateTime? @db.DateTime(0) // 上次巡航时间（做 TTL 复用）
  parent_check_reason       String?   @db.VarChar(255) // 巡航结论说明 / 失败原因
  // 换链接相关
  kyads_referer_url         String?   @db.VarChar(1024) // 手动覆盖来路URL（为空则自动取最新已发布文章URL）
  // ATC 广告情报字段
  atc_advertiser_count      Int?      @db.UnsignedInt // ATC 真实广告主数（已过滤商家自身和代理商）
  atc_last_synced_at        DateTime? @db.DateTime(0) // 最后 ATC 同步时间
  atc_sync_status           String    @default("idle") @db.VarChar(16) // idle / syncing / done / error
  // D-050：D-046.A IntelliCenter 商家画像 14 字段已回滚（07 拍板：画像改内存临时生成，不存库）
  is_deleted                Int       @default(0) @db.TinyInt
  created_at                DateTime  @default(now()) @db.DateTime(0)
  updated_at                DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, status], map: "idx_user_status")
  @@index([user_id, platform], map: "idx_user_platform")
  @@index([user_id, platform, merchant_id], map: "idx_user_plat_mid")
  @@index([violation_status], map: "idx_violation_status")
  @@index([user_id, source], map: "idx_user_source")
  // C-079：从 MariaDB 慢查询日志发现，txn-quick-sync / 商家归属重定向等场景大量
  // WHERE merchant_id + platform 查询无前缀 user_id，旧索引全部失效导致全表扫描 644K 行 / 6.6s。
  // 加 (merchant_id, platform) 复合索引后单次查询 < 5ms。
  @@index([merchant_id, platform], map: "idx_merchant_platform")
}

// -----------------------------------------------------------
// 6a1. 上级联盟库（追踪链接巡航识别用）
//   原 hermes-crm/门户维护，现在主 CRM 自建为权威源。
//   label：上级联盟名（小写，如 awin / impact / cj / shareasale）
//   match_keywords：识别关键词数组（小写，含名字 / 跳板域名 / 特征参数），
//     整条跳转链命中任一关键词即判定属于该上级联盟。
// -----------------------------------------------------------
model parent_networks {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  label          String   @unique(map: "uk_parent_label") @db.VarChar(64)
  display_name   String?  @db.VarChar(128)
  match_keywords Json // string[]（小写）
  note           String?  @db.VarChar(255)
  status         String   @default("active") @db.VarChar(16) // active / disabled
  created_at     DateTime @default(now()) @db.DateTime(0)
  updated_at     DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([status], map: "idx_parent_status")
}

// -----------------------------------------------------------
// 6a1b. 各联盟平台的上级联盟黑名单（命中即创建广告时硬拦截）
//   platform：联盟平台代号（user_merchants.platform），* 表示全平台
//   parent_label：引用 parent_networks.label（小写）
// -----------------------------------------------------------
model platform_blacklist {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  platform     String   @db.VarChar(16)
  parent_label String   @db.VarChar(64)
  note         String?  @db.VarChar(255)
  status       String   @default("active") @db.VarChar(16) // active / disabled
  created_at   DateTime @default(now()) @db.DateTime(0)
  updated_at   DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@unique([platform, parent_label], map: "uk_platform_parent")
  @@index([platform], map: "idx_bl_platform")
}

// -----------------------------------------------------------
// 6a2. D-050 广告拒登反馈（事后学习负样本，员工在数据中心手动录入，零 API）
// 用途：被 Google 拒登的广告，员工一键记录真实拒登原因 + 自动抓被拒文案快照，
//       下次给同商家（强约束）/ 同行业（软提示）生成广告时注入 prompt，规避再次被拒。
// -----------------------------------------------------------
model ad_rejection_feedback {
  id                    BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id               BigInt    @db.UnsignedBigInt // 广告归属员工（同商家/同行业范围按此过滤）
  campaign_id           BigInt?   @db.UnsignedBigInt // 关联 campaigns.id（可空，防级联删）
  google_campaign_id    String?   @db.VarChar(32)
  campaign_name         String?   @db.VarChar(255)
  user_merchant_id      BigInt?   @db.UnsignedBigInt // 关联商家，用于"同商家强约束"
  merchant_name         String?   @db.VarChar(255)
  merchant_url          String?   @db.VarChar(512)
  industry_category     String?   @db.VarChar(64) // 用于"同行业软提示"（来自内存画像，可空）
  policy_category       String    @db.VarChar(64) // 政策类别（policy-hub 分类 code）
  reason_text           String    @db.Text // 员工填写的具体拒登原因
  rejected_headlines    Json? // 被拒时的标题快照
  rejected_descriptions Json? // 被拒时的描述快照
  created_by            BigInt?   @db.UnsignedBigInt // 录入员工 user_id
  is_deleted            Int       @default(0) @db.TinyInt
  created_at            DateTime  @default(now()) @db.DateTime(0)
  updated_at            DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_merchant_id], map: "idx_arf_merchant")
  @@index([industry_category], map: "idx_arf_industry")
  @@index([campaign_id], map: "idx_arf_campaign")
  @@index([user_id], map: "idx_arf_user")
}

// -----------------------------------------------------------
// 6b. 商家违规记录表（从 Google Sheets 同步）
// -----------------------------------------------------------
model merchant_violations {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  merchant_name    String    @db.VarChar(255)
  platform         String    @default("") @db.VarChar(32)
  merchant_domain  String?   @db.VarChar(255)
  violation_reason String?   @db.Text
  violation_time   DateTime? @db.DateTime(0)
  source           String?   @db.VarChar(100) // 名单来源
  upload_batch     String    @db.VarChar(64)
  is_deleted       Int       @default(0) @db.TinyInt
  created_at       DateTime  @default(now()) @db.DateTime(0)

  @@index([merchant_name], map: "idx_vio_name")
}

// -----------------------------------------------------------
// 6c. 推荐商家记录表（从 Google Sheets 同步 或 Excel 上传）
// -----------------------------------------------------------
model merchant_recommendations {
  id                   BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  merchant_name        String   @db.VarChar(255)
  roi_reference        String?  @db.VarChar(64)
  commission_info      String?  @db.VarChar(64) // 佣金率
  settlement_info      String?  @db.VarChar(64) // 结算率
  remark               String?  @db.Text // 标记/备注
  share_time           String?  @db.VarChar(32) // 分享时间
  upload_batch         String   @db.VarChar(64)
  // Excel 导入扩展字段
  source               String   @default("sheets") @db.VarChar(16) // sheets / excel
  mcid                 String?  @db.VarChar(64) // 平台内部商家代码
  mid                  String?  @db.VarChar(64) // 数字型商家 ID
  affiliate            String?  @db.VarChar(128) // 所属联盟平台（Impact/Rakuten/PHG 等）
  website              String?  @db.VarChar(512) // 商家官网
  merchant_base        String?  @db.VarChar(128) // 商家地区（如 US/GB/CA）
  epc                  Decimal? @db.Decimal(12, 4) // 每次点击收益
  commission_cap       String?  @db.VarChar(256) // 预计最高AFF佣金上限（可能是数字或文本）
  avg_commission_rate  Decimal? @db.Decimal(12, 6) // 平均佣金率（Payout，小数）
  avg_order_commission Decimal? @db.Decimal(12, 4) // 平均带单佣金（Payout，美元）
  is_deleted           Int      @default(0) @db.TinyInt
  created_at           DateTime @default(now()) @db.DateTime(0)

  @@index([merchant_name], map: "idx_rec_name")
  @@index([mid], map: "idx_rec_mid")
  @@index([source], map: "idx_rec_source")
}

// -----------------------------------------------------------
// 6d. 共享表格配置（存储 Google Sheets 链接）
// -----------------------------------------------------------
model sheet_configs {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  config_type    String    @unique @db.VarChar(32) // violation / recommendation / merchant_sheet
  sheet_url      String    @db.Text
  last_synced_at DateTime? @db.DateTime(0)
  updated_by     BigInt?   @db.UnsignedBigInt
  is_deleted     Int       @default(0) @db.TinyInt
  created_at     DateTime  @default(now()) @db.DateTime(0)
  updated_at     DateTime  @default(now()) @updatedAt @db.DateTime(0)
}

// -----------------------------------------------------------
// 7. 广告默认设置表
// -----------------------------------------------------------
model ad_default_settings {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_id          BigInt   @unique(map: "uk_user") @db.UnsignedBigInt
  bidding_strategy String   @default("MAXIMIZE_CLICKS") @db.VarChar(32)
  ecpc_enabled     Int      @default(1) @db.TinyInt
  max_cpc          Decimal  @default(0.30) @db.Decimal(10, 2)
  daily_budget     Decimal  @default(2.00) @db.Decimal(10, 2)
  network_search   Int      @default(1) @db.TinyInt
  network_partners Int      @default(0) @db.TinyInt
  network_display  Int      @default(0) @db.TinyInt
  naming_rule      String   @default("global") @db.VarChar(20) // global | per_platform
  naming_prefix    String   @default("") @db.VarChar(10) // 全局序号前缀（空=纯数字）
  eu_political_ad  Int      @default(0) @db.TinyInt // 0=不含EU政治广告 1=含
  ai_rule_profile  Json?
  is_deleted       Int      @default(0) @db.TinyInt
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @default(now()) @updatedAt @db.DateTime(0)
}

// -----------------------------------------------------------
// 8. 节日日历表
// -----------------------------------------------------------
model holiday_calendar {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  country_code     String   @db.VarChar(8)
  holiday_name     String   @db.VarChar(128)
  holiday_date     DateTime @db.Date
  holiday_type     String   @default("commercial") @db.VarChar(16)
  related_holidays Json?
  is_deleted       Int      @default(0) @db.TinyInt
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([country_code, holiday_date], map: "idx_country_date")
}

// -----------------------------------------------------------
// 9. 广告系列表
// -----------------------------------------------------------
model campaigns {
  id                         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                    BigInt    @db.UnsignedBigInt
  user_merchant_id           BigInt    @db.UnsignedBigInt
  // 该广告归属的联盟账号（连接）。建广告时按当时选链接用的账号写入，是「这条广告用哪个号的链接」的唯一可靠依据。
  // NULL = 存量未回填（回退旧逻辑：用商家主连接/tracking_link）。换链 / 刷点击 / 订单归属均以此为准，
  // 避免商家主连接随重同步漂移导致「换错号 / 刷到没出单的号」（wj02 CG1/CG2 串号问题）。
  platform_connection_id     BigInt?   @db.UnsignedBigInt
  google_campaign_id         String?   @db.VarChar(64)
  mcc_id                     BigInt?   @db.UnsignedBigInt
  customer_id                String?   @db.VarChar(32)
  campaign_name              String?   @db.VarChar(255)
  daily_budget               Decimal   @default(2.00) @db.Decimal(10, 2)
  bidding_strategy           String    @default("MAXIMIZE_CLICKS") @db.VarChar(32)
  max_cpc_limit              Decimal?  @db.Decimal(10, 2)
  target_country             String    @db.VarChar(8)
  geo_target                 String?   @db.VarChar(16)
  language_id                String?   @db.VarChar(16)
  network_search             Int       @default(1) @db.TinyInt
  network_partners           Int       @default(0) @db.TinyInt
  network_display            Int       @default(0) @db.TinyInt
  status                     String    @default("active") @db.VarChar(16)
  google_status              String    @default("ENABLED") @db.VarChar(16) // Google Ads 侧真实状态: ENABLED / PAUSED / REMOVED
  last_google_sync_at        DateTime? @db.DateTime(0) // 最后一次从 Google 同步状态的时间
  // D-040 v2: 重发广告历史 gcid 列表（含旧 gcid 数组），用于 cost 合并 + GAds REMOVED 数据补救
  // 格式: ["23663238670", "23864905107"] — 不含 current google_campaign_id
  // 用途: status-sync / daily-sync 拉 GAds REMOVED 广告时按 previous_gcids 匹配回原 campaign，cost 合并不丢
  previous_gcids             Json      @default("[]") // 历史重发广告的 Google Ads gcid 数组
  // Google Ads 网址选项
  final_url_suffix           String?   @db.VarChar(500) // 最终到达网址后缀（附加到落地页 URL 末尾的 UTM 参数等）
  // 换链接相关字段
  suffix_exchange_enabled    Int       @default(1) @db.TinyInt // 是否参与换链（可单独关闭）
  suffix_needs_browser       Int       @default(0) @db.TinyInt // 1=该系列必须无头浏览器才能跟链（生成成功时按 usedBrowser 自动学习），补货走低频/低水位省代理流量
  suffix_is_static           Int       @default(0) @db.TinyInt // 1=静态后缀商家（落地页参数不随会话变化，补货全为重复内容时自动学习；产出新内容时自动清 0）。库存天然≤不同内容数，前端不按低水位标红
  suffix_last_content        String?   @db.Text // 最近一次写入的 Suffix 内容（展示用）
  suffix_last_apply_at       DateTime? @db.DateTime(0) // 最近换链时间
  suffix_click_baseline      Int       @default(0) @db.Int // 脚本退出前记录的点击数基线，下次启动时读取以跨实例延续
  suffix_click_checkpoint_at DateTime? @db.DateTime(0) // 基线记录时间
  is_deleted                 Int       @default(0) @db.TinyInt
  created_at                 DateTime  @default(now()) @db.DateTime(0)
  updated_at                 DateTime  @default(now()) @updatedAt @db.DateTime(0)

  @@index([user_id, is_deleted], map: "idx_user")
  @@index([user_id, status, is_deleted], map: "idx_user_status_del")
  @@index([user_id, mcc_id], map: "idx_user_mcc")
  @@index([user_merchant_id], map: "idx_user_merchant")
  @@index([google_campaign_id], map: "idx_google_campaign")
  @@index([platform_connection_id], map: "idx_platform_connection")
}

